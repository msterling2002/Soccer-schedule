<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= coach ? 'Edit Coach' : 'Add Coach' %> – PSJ Soccer</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f0f4fa; color: #0d1f3c; min-height: 100vh; }
    .header {
      background: #0d3580; color: #fff;
      padding: 1.2rem 2rem; display: flex; align-items: center; gap: 1rem;
    }
    .header h1 { font-size: 1.5rem; font-weight: 700; }
    .header h1 span { color: #f5c400; }
    .header-actions { margin-left: auto; }
    .btn-back {
      padding: 0.4rem 0.9rem; background: rgba(255,255,255,0.15); color: #fff;
      text-decoration: none; border: 1px solid rgba(255,255,255,0.3); border-radius: 6px; font-size: 0.82rem;
    }
    .btn-back:hover { background: rgba(255,255,255,0.25); }
    .content { padding: 2rem; max-width: 480px; margin: 0 auto; }
    .form-card {
      background: #fff; border: 1px solid #d0d9ec; border-radius: 10px; padding: 1.5rem;
    }
    .field { margin-bottom: 1.1rem; }
    label { display: block; font-size: 0.82rem; font-weight: 600; color: #555; margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 0.04em; }
    input {
      width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #c0cce0; border-radius: 6px;
      font-size: 1rem; color: #0d1f3c; background: #f9fafb;
    }
    input:focus { outline: none; border-color: #0d3580; }
    .btn-submit {
      padding: 0.5rem 1.2rem; background: #0d3580; color: #fff;
      border: none; border-radius: 6px; font-size: 0.95rem; font-weight: 600; cursor: pointer;
    }
    .btn-submit:hover { background: #0a2a66; }
    .btn-cancel {
      padding: 0.5rem 1rem; background: #e6ecf8; color: #0d3580;
      text-decoration: none; border-radius: 6px; font-size: 0.95rem; font-weight: 600; margin-left: 0.5rem;
    }
    .btn-cancel:hover { background: #c5d3f0; }
  </style>
</head>
<body>
<div class="header">
  <h1>PSJ <span><%= coach ? 'Edit Coach' : 'Add Coach' %></span></h1>
  <div class="header-actions">
    <a class="btn-back" href="/coaches">Back</a>
  </div>
</div>
<div class="content">
  <div class="form-card">
    <form method="POST" action="<%= action %>">
      <div class="field">
        <label for="coach_name">Coach Name</label>
        <input type="text" id="coach_name" name="coach_name" required
               value="<%= coach ? coach.coach_name : '' %>">
      </div>
      <div class="field">
        <label for="team_name">Team Name</label>
        <input type="text" id="team_name" name="team_name" required
               value="<%= coach ? coach.team_name : '' %>"
               placeholder="e.g. PSJ United 2016 U10 CC">
      </div>
      <button class="btn-submit" type="submit"><%= coach ? 'Save Changes' : 'Add Coach' %></button>
      <a class="btn-cancel" href="/coaches">Cancel</a>
    </form>
  </div>
</div>
</body>
</html>
